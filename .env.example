# App
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL — required from Phase 1 onward
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shosetu_reader

# Redis — required from Phase 3 onward (job queue)
REDIS_URL=redis://localhost:6379

# OpenRouter — required for translation
# OPENROUTER_API_KEY=sk-or-...

# Default model used when a workload-specific override is not set.
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-v4-flash

# DeepSeek V4 best-practice pairing — Flash for routine throughput,
# Pro for quality-sensitive single-shots. Tweak per workload as needed.
OPENROUTER_TRANSLATE_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_TITLE_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SUMMARY_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_EXTRACTION_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_COMPARE_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_BOOTSTRAP_MODEL=deepseek/deepseek-v4-pro

# Reasoning effort per workload (off | low | high | xhigh).
# Translation runs reasoning OFF so V4 doesn't burn output tokens on
# chain-of-thought during routine body translation. Glossary extraction
# benefits from light reasoning; bootstrap and compare want HIGH.
OPENROUTER_REASONING_TRANSLATE=off
OPENROUTER_REASONING_TITLE=off
OPENROUTER_REASONING_SUMMARY=off
OPENROUTER_REASONING_EXTRACTION=low
OPENROUTER_REASONING_COMPARE=high
OPENROUTER_REASONING_BOOTSTRAP=high

# Per-workload max-tokens overrides. Defaults: translate=4096 · title=1024 ·
# summary=2048 · extraction=4096 · compare=8192 · bootstrap=8192.
# DeepSeek V4 supports up to 384K output tokens; bump if you see truncation.
# OPENROUTER_MAX_TOKENS_TRANSLATE=4096
# OPENROUTER_MAX_TOKENS_EXTRACTION=4096

# Provider routing pin — comma-separated provider list. DeepSeek-family
# models pin to DeepSeek by default so OpenRouter doesn't route to a
# fallback host outside DeepSeek's KV-cache domain (~50× cheaper hits).
# Set to an empty string to disable auto-pinning.
OPENROUTER_PROVIDER_PIN=DeepSeek

# Max glossary entries injected into the translation prompt (default 500).
# 500 × ~80 tokens ≈ 40K tokens — fits comfortably in V4 1M context.
# GLOSSARY_MAX_PROMPT_ENTRIES=500

# Translation cost budget per session, in USD. When exceeded the session
# auto-pauses (status='paused_budget') so a runaway can be inspected.
# TRANSLATION_COST_BUDGET_USD=2.0

# Admin — required in production for /api/admin/* endpoints
# Generate with: openssl rand -hex 32
# ADMIN_API_KEY=
