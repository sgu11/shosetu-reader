# App
NODE_ENV=development
APP_URL=http://localhost:3000

# PostgreSQL — required from Phase 1 onward
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shosetu_reader

# Redis — required from Phase 3 onward (job queue)
REDIS_URL=redis://localhost:6379

# OpenRouter — required for translation
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash-lite

# Admin — required in production for /api/admin/* endpoints
# Generate with: openssl rand -hex 32
# ADMIN_API_KEY=
